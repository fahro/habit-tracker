# Development Dockerfile with hot reload
FROM node:18-alpine

# Install build dependencies
RUN apk add --no-cache python3 make g++ sqlite

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install all dependencies (including dev)
RUN npm install

# Copy source code
COPY . .

# Expose ports for Vite and API
EXPOSE 3000 3001

# Start development server
CMD ["npm", "run", "dev"]
